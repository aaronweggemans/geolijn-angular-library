{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "libs",
  "projects": {
    "geodata-core": {
      "projectType": "library",
      "root": "libs/geodata-core",
      "sourceRoot": "libs/geodata-core/src",
      "prefix": "geolijn",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "libs/geodata-core/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/geodata-core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/geodata-core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "libs/geodata-core/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    },
    "geodata-generieke-componenten": {
      "projectType": "library",
      "root": "libs/geodata-generieke-componenten",
      "sourceRoot": "libs/geodata-generieke-componenten/src",
      "prefix": "geolijn",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "libs/geodata-generieke-componenten/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/geodata-generieke-componenten/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/geodata-generieke-componenten/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "libs/geodata-generieke-componenten/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    },
    "storybook": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/storybook",
      "sourceRoot": "projects/storybook/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/storybook",
            "index": "projects/storybook/src/index.html",
            "browser": "projects/storybook/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/storybook/tsconfig.app.json",
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kB",
                  "maximumError": "4kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "storybook:build:production"
            },
            "development": {
              "buildTarget": "storybook:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "projects/storybook/.storybook",
            "browserTarget": "storybook:build",
            "compodoc": false,
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "projects/storybook/.storybook",
            "browserTarget": "storybook:build",
            "compodoc": false,
            "outputDir": "dist/storybook/storybook"
          }
        }
      }
    }
  }
}
