{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "libs",
  "projects": {
    "geodata-core": {
      "projectType": "library",
      "root": "libs/geodata-core",
      "sourceRoot": "libs/geodata-core/src",
      "prefix": "geolijn",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "libs/geodata-core/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/geodata-core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/geodata-core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "libs/geodata-core/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "libs/geodata-core/.storybook",
            "browserTarget": "geodata-core:build",
            "compodoc": true,
            "compodocArgs": [
              "-e",
              "json",
              "-d",
              "libs/geodata-core"
            ],
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "libs/geodata-core/.storybook",
            "browserTarget": "geodata-core:build",
            "compodoc": true,
            "compodocArgs": [
              "-e",
              "json",
              "-d",
              "libs/geodata-core"
            ],
            "outputDir": "dist/storybook/geodata-core"
          }
        }
      }
    },
    "geodata-generieke-componenten": {
      "projectType": "library",
      "root": "libs/geodata-generieke-componenten",
      "sourceRoot": "libs/geodata-generieke-componenten/src",
      "prefix": "geolijn",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "libs/geodata-generieke-componenten/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/geodata-generieke-componenten/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/geodata-generieke-componenten/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "libs/geodata-generieke-componenten/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "libs/geodata-generieke-componenten/.storybook",
            "browserTarget": "geodata-generieke-componenten:build",
            "compodoc": true,
            "compodocArgs": [
              "-e",
              "json",
              "-d",
              "libs/geodata-generieke-componenten"
            ],
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "libs/geodata-generieke-componenten/.storybook",
            "browserTarget": "geodata-generieke-componenten:build",
            "compodoc": true,
            "compodocArgs": [
              "-e",
              "json",
              "-d",
              "libs/geodata-generieke-componenten"
            ],
            "outputDir": "dist/storybook/geodata-generieke-componenten"
          }
        }
      }
    }
  }
}